@article{liu2024stability,
  selected={true},
  title = {Rheological properties of SBS-modified asphalt containing aluminum hydroxide and organic montmorillonite},
  author = {Jiale Liu and Sarah O'Connor*},
  year = {2023},
  month = sep,
  journal = {Case Studies in Construction Materials},
  volume = {19},
  pages = {e02491},
  issn = {2214-5095},
  doi = {10.1016/j.cscm.2023.e02491},
  urldate = {2024-12-02},
  langid = {english},
  abstract = {The composite flame retardant composed of aluminum hydroxide (ATH) and organic montmorillonite (OMMT) is of potential application value in the tunnel asphalt pavement. To investigate the effect of ATH and OMMT on the rheological properties of SBS modified asphalt at high and low temperatures. In this study, the composite ATH/OMMT/SBS modified asphalt was subjected to multiple stress creep recovery (MSCR), linear amplitude sweep test (LAS), and Bending beam rheometer (BBR) experiments. Analysis of high and low temperature rheological properties and fatigue properties of composite ATH/OMMT/SBS modified asphalt under the conditions of single incorporation and composite modification. The findings of the tests suggest that ATH can significantly improve the fatigue life but has adverse impact on the creep recovery property of asphalt materials, OMMT has a significant improvement effect on the low-temperature performance, however, the detrimental effect of OMMT on fatigue performance is greater than the improvement of ATH. The research results provide a reference for the practical application of flame retardants.},
  description={},
  keywords={Tunnel asphalt pavement, Composite modified asphalt, Aluminum hydroxide, Organic montmorillonite, Rheological properties}
}

@inproceedings{smith2024constructive,
  title = {A Constructive Proof of the Generalized Riemann Hypothesis for Function Fields over Finite Constants},
  booktitle = {Proceedings of the 2024 International Congress of Mathematicians (ICM)},
  author = {John Smith# and Jiale Liu#* and Alan Turing},
  year = {2024},
  month = jun,
  pages = {205--218},
  publisher = {EMS Press},
  address = {Paris, France},
  doi = {10.4171/ICM2024/102},
  urldate = {2024-12-02},
  isbn = {978-3-03719-202-8},
  abstract = {We present a novel constructive proof for the Generalized Riemann Hypothesis (GRH) specifically within the context of function fields over finite constants. Unlike previous existential approaches, our method utilizes the spectral interpretation of the Frobenius automorphism acting on étale cohomology groups. We explicitly construct the L-functions associated with algebraic curves and demonstrate that their zeros lie strictly on the critical line Re(s) = 1/2. This work bridges the gap between classical analytic number theory and geometric invariant theory, offering new insights into the distribution of prime polynomials. The constructive nature of our proof allows for the algorithmic verification of L-function properties for curves of genus g > 100, which was previously computationally intractable.},
  preview={example.png},
  description={A constructive proof demonstrating the validity of the Generalized Riemann Hypothesis for function fields using spectral interpretation of the Frobenius automorphism.},
  keywords={Number Theory, Riemann Hypothesis, Function Fields, Algebraic Geometry}
}

@inproceedings{brown2023monte,
  selected={true},
  title = {Monte Carlo Simulations of Phase Transitions in 2D Ising Models on Non-Euclidean Lattices},
  shorttitle = {Ising on Hyperbolic Planes},
  booktitle = {2023 International Conference on Computational Physics (ICCP)},
  author = {Charlie Brown and Jiale Liu*},
  year = {2023},
  month = dec,
  pages = {45--52},
  publisher = {APS},
  address = {Tokyo, Japan},
  doi = {10.1103/ICCP.2023.0045},
  urldate = {2024-12-02},
  isbn = {978-0-7354-2000-1},
  abstract = {The behavior of spin systems on curved geometries offers a unique window into the interplay between topology and statistical mechanics. This study employs extensive Monte Carlo simulations to explore the phase transitions of the 2D Ising model mapped onto hyperbolic lattices (Poincaré disk). We utilize the Wolff cluster algorithm to overcome critical slowing down near the phase transition temperature. Our results indicate that the critical exponents on negatively curved surfaces deviate significantly from the standard Onsager solution for flat Euclidean lattices. Specifically, we observe a suppression of the correlation length divergence, suggesting a mean-field-like behavior induced by the exponential expansion of the lattice volume. These findings have implications for understanding quantum gravity models and holographic duality.},
  preview={example.png},
  description={Monte Carlo study revealing mean-field-like phase transitions and critical exponent deviations for Ising models on hyperbolic non-Euclidean lattices.},
  keywords={Statistical Mechanics, Monte Carlo Simulation, Ising Model, Non-Euclidean Geometry}
}

@article{doe2025existence,
  title = {On the Existence and Uniqueness of Solutions to Non-Linear Stochastic Partial Differential Equations},
  author = {Jane Doe and Jiale Liu and Richard Feynman},
  year = {2025},
  month = jun,
  journal = {Annals of Probability},
  volume = {53},
  number = {4},
  pages = {1201--1245},
  issn = {0091-1798},
  doi = {10.1214/25-AOP1201},
  copyright = {https://imstat.org/journals-and-publications/annals-of-probability/},
  abstract={We establish the existence and uniqueness of strong solutions for a class of non-linear Stochastic Partial Differential Equations (SPDEs) driven by multiplicative Lévy noise. The equations under consideration model turbulent fluid flow and heat transport in random media. By employing a Galerkin approximation scheme combined with a compact embedding theorem, we prove the convergence of the approximate solutions in appropriate Hilbert spaces. Furthermore, we derive a priori estimates that ensure the global regularity of the solution almost surely. A key contribution of this work is the treatment of non-Lipschitz coefficients using a stochastic Gronwall inequality, extending the applicability of the theory to more singular physical models. We also discuss the ergodic properties of the invariant measures associated with the SPDEs.},
  preview={example.png},
  description={Mathematical proof of existence and uniqueness for non-linear SPDEs with multiplicative Lévy noise, extending theory to non-Lipschitz coefficients.},
  keywords={Stochastic Analysis, SPDE, Existence Theorems, Probability Theory}
}


@article{liu2025algorithmic,
  title = {Algorithmic Complexity of Tensor Network Contractions in Many-Body Localization},
  author = {Jiale Liu and Ada Lovelace*},
  year = {2025},
  month = sep,
  journal = {Physical Review E},
  issn = {2470-0045},
  publisher = {APS},
  abstract = {Simulating the dynamics of many-body localized (MBL) systems poses a significant challenge due to the logarithmic growth of entanglement entropy. This paper analyzes the algorithmic complexity of contracting Tensor Networks, specifically Matrix Product States (MPS) and Projected Entangled Pair States (PEPS), when applied to MBL Hamiltonians. We prove that while the exact contraction is #P-complete, approximate contraction schemes based on singular value decomposition (SVD) truncation exhibit polynomial time complexity with bounded error for short-time evolution. However, we identify a "complexity phase transition" at the ergodic-MBL transition point, where the bond dimension required for a fixed accuracy diverges exponentially. We propose a novel adaptive bond-dimension algorithm that optimizes computational resources by exploiting the area law of entanglement in the localized phase, demonstrating superior performance on Heisenberg spin chains.},
  description={Complexity analysis of tensor network contractions in MBL systems, identifying a complexity phase transition and proposing an adaptive algorithm.},
  keywords={Tensor Networks, Many-Body Localization, Complexity Theory, Quantum Information},
  doi = {10.1103/PhysRevE.112.092101},
  selected = {true},
  code = {https://github.com/xyjoey/PRISM},
}
